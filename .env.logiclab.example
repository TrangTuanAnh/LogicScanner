# Generate a new value; never deploy the development token.
LOGICLAB_API_TOKEN=replace-with-a-random-token-of-at-least-32-characters

# SQLite quick start. PostgreSQL example:
# postgresql+psycopg://logiclab:logiclab@127.0.0.1:15432/logiclab
LOGICLAB_DATABASE_URL=sqlite:///./.logiclab/logiclab.db
LOGICLAB_API_HOST=127.0.0.1
LOGICLAB_API_PORT=8088
LOGICLAB_DEVELOPMENT_MODE=false
LOGICLAB_SESSION_COOKIE_SECURE=false
LOGICLAB_LEGACY_RUNTIME_ENABLED=false

# Optional semantic proposer. Off keeps interpretation reproducible; on requires
# a local Ollama model and marks every proposed claim as INFERRED.
LOGICLAB_PROPOSER_ENABLED=false
# LOGICLAB_PROPOSER_MODEL=qwen2.5-coder:14b
# LOGICLAB_PROPOSER_BASE_URL=http://127.0.0.1:11434
# LOGICLAB_PROPOSER_MAX_CLAIMS=25
LOGICLAB_ARTIFACT_ROOT=.logiclab/artifacts
LOGICLAB_WORKSPACE_ROOT=.logiclab/workspaces
